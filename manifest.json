<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema Integrado de Consulta de Servidores - DGF</title>

<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#002b5c">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/1087/1087080.png">

<style>
/* --- BASE E RESET --- */
* { margin: 0; padding: 0; box-sizing: border-box; }

body { 
    font-family: 'Segoe UI', sans-serif; 
    background: radial-gradient(circle at top left, #f0f4f8 0%, #d9e2ec 100%);
    background-attachment: fixed;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* --- TOPO --- */
.topbar { background: #002b5c; color: white; padding: 18px 30px; font-size: 18px; font-weight: 600; flex-shrink: 0; }
.topbar small { display: block; font-size: 12px; opacity: 0.8; }
.gold-line { height: 4px; background: #c9a227; flex-shrink: 0; }

.main { 
    flex: 1; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    padding: 15px;
}

/* --- CONTAINER DINÂMICO --- */
.container { 
    background: rgba(255, 255, 255, 0.98); 
    padding: 30px; border-radius: 16px; width: 460px; 
    box-shadow: 0 20px 60px rgba(0,0,0,0.12); 
    z-index: 2; 
    transition: all 0.4s ease;
    max-height: 95vh;
    overflow-y: auto;
}

/* MODO SISTEMA (DESKTOP) */
.container.modo-sistema { 
    width: 98%; 
    max-width: 1280px; 
    display: flex; 
    gap: 25px; 
}

.col-sistema-principal { flex: 1; display: flex; gap: 20px; min-width: 0; }
.col-busca { flex: 1.2; min-width: 0; }
.col-organograma { flex: 0.8; background: #f1f5f9; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0; }
.col-dashboard-lateral { width: 300px; display: flex; flex-direction: column; gap: 15px; flex-shrink: 0; }

/* --- COMPONENTES --- */
.status-box { background: white; padding: 20px; border-radius: 12px; border-top: 5px solid #002b5c; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
.sanfona-item { background: white; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 5px; }
.sanfona-header { background: #002b5c; padding: 12px; font-weight: bold; color: white; font-size: 10px; text-transform: uppercase; text-align: center; cursor: pointer; }
.sanfona-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease-out; }
.sanfona-content.open { max-height: 400px; padding: 15px; overflow-y: auto; border-top: 1px solid #eee; }

.response { 
    margin-top: 20px; background: #f8fafc; padding: 20px; border-radius: 12px; 
    border-left: 5px solid #002b5c; height: 400px; overflow-y: auto; 
}

.card-resultado { border-bottom: 1px solid #edf2f7; padding: 15px 0; width: 100%; }
.info-item { display: block; margin-bottom: 4px; font-size: 13px; }

input { width: 100%; padding: 14px; border-radius: 8px; border: 1px solid #d1d9e6; margin-bottom: 12px; }
button { width: 100%; padding: 14px; border-radius: 8px; border: none; background: #002b5c; color: white; font-weight: 600; cursor: pointer; }
.logout { background: #d32f2f; margin-top: 15px; }
.org-item { background: white; padding: 12px; border-radius: 8px; margin-bottom: 10px; border-left: 4px solid #002b5c; cursor: pointer; }

/* --- AJUSTES PARA CELULAR (MOBILE) --- */
@media (max-width: 850px) {
    body { overflow-y: auto; }
    .main { align-items: flex-start; padding: 10px; }
    
    .container.modo-sistema { 
        flex-direction: column;
        width: 100%; 
        max-height: none;
        padding: 20px;
    }

    .col-sistema-principal { flex-direction: column; width: 100%; }
    .col-dashboard-lateral { width: 100%; order: -1; }
    .col-organograma { margin-left: 0 !important; }
    .response { height: 350px; }
    .topbar { padding: 15px; font-size: 16px; }
}

.footer { text-align: center; padding: 12px; font-size: 11px; color: #64748b; background: rgba(233, 237, 242, 0.9); border-top: 1px solid #d1d9e6; flex-shrink: 0; }
.hidden { display: none !important; }
.update-item { padding: 8px; border-bottom: 1px solid #f0f0f0; font-size: 11px; display: flex; gap: 8px; }
.pass-container { position: relative; }
.toggle-eye { position: absolute; right: 15px; top: 14px; cursor: pointer; opacity: 0.5; }
</style>
</head>

<body>

<div class="topbar">
Secretaria Estadual de Pernambuco - DGF
<small>Sistema Interno de Gestão de Dados</small>
</div>
<div class="gold-line"></div>

<div class="main">
    <div id="mainContainer" class="container">
        
        <div id="loginArea">
            <div style="text-align: center; margin-bottom: 25px;">
                <img src="brasao-dgf.png" alt="DGF" style="height: 60px;">
                <h2 style="margin-top: 10px;">Acesso Institucional</h2>
            </div>
            <input type="text" id="usuario" placeholder="CPF ou Usuário">
            <div class="pass-container">
                <input type="password" id="senha" placeholder="Senha de acesso">
                <span class="toggle-eye" onclick="verSenha('senha')">👁️</span>
            </div>
            <button onclick="login()">Autenticar Usuário</button>
        </div>

        <div id="trocaSenhaArea" class="hidden">
            <h2>🔒 Alterar Senha</h2>
            <div class="pass-container">
                <input type="password" id="novaSenha" placeholder="Nova senha">
                <span class="toggle-eye" onclick="verSenha('novaSenha')">👁️</span>
            </div>
            <div class="pass-container">
                <input type="password" id="confirmaSenha" placeholder="Confirme a senha">
                <span class="toggle-eye" onclick="verSenha('confirmaSenha')">👁️</span>
            </div>
            <button onclick="salvarNovaSenha()">Atualizar e Entrar</button>
        </div>

        <div id="sistemaArea" class="col-sistema-principal hidden">
            <div class="col-busca">
                <h2>Consulta</h2>
                <input type="text" id="pergunta" placeholder="O que deseja consultar?">
                <button onclick="consultar()">Buscar</button>
                <div class="response" id="resposta"></div>
                <button class="logout" onclick="logout()">Sair</button>
            </div>

            <div class="col-organograma">
                <div style="font-weight: 700; font-size: 12px; margin-bottom: 15px; color: #002b5c;">📌 ESTRUTURA</div>
                <div class="org-item" onclick="buscaRapida('Diretor')"><span>👑 Diretor Geral</span></div>
                <div class="org-item" onclick="buscaRapida('Superintendente')"><span>👔 Superintendentes</span></div>
                <div class="org-item" onclick="buscaRapida('Gerente')"><span>📂 Gerentes</span></div>
            </div>
        </div>

        <div id="dashboardDireito" class="col-dashboard-lateral hidden">
            <div class="status-box">
                <h3 id="relogio" style="font-size: 24px; color: #002b5c;">00:00:00</h3>
                <p style="font-size: 10px; color: #c9a227; font-weight: 800;">● Sessão Ativa</p>
            </div>
            <div class="sanfona-item">
                <div class="sanfona-header" onclick="tglS('accLogs')">Logs</div>
                <div id="accLogs" class="sanfona-content"><div id="listaLogs"></div></div>
            </div>
            <div class="sanfona-item">
                <div class="sanfona-header" onclick="tglS('accLinks')">Links</div>
                <div id="accLinks" class="sanfona-content">
                    <a href="https://efisco.sefaz.pe.gov.br/" target="_blank" style="display:block; padding:10px; text-align:center; text-decoration:none; color:#002b5c; font-weight:bold;">E-FISCO</a>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="footer">© 2026 - DGF</div>

<script>
/* --- LÓGICA INTEGRAL MANTIDA --- */
const WEBHOOK_URL = "https://script.google.com/macros/s/AKfycby_2RVDaGqMWGs_Ybd2sftswVU2EF4YYa5Qv3mXiLKidMnNKRhDSmRis0zbSmB6NWT2/exec";
const TEMPO_EXPIRACAO = 30 * 60 * 1000;
let cacheLogs = []; 

function atualizarRelogio() { document.getElementById("relogio").innerText = new Date().toLocaleTimeString('pt-BR'); }
setInterval(atualizarRelogio, 1000);
function tglS(id) { document.getElementById(id).classList.toggle("open"); }

function buscaRapida(cargo) {
    document.getElementById("pergunta").value = "cargo de " + cargo;
    window.consultar();
}

async function carregarLogs() {
    if (localStorage.getItem("logado") !== "true") return;
    try {
        const response = await fetch(WEBHOOK_URL + "?getLogs=true&t=" + Date.now());
        const logs = await response.json();
        cacheLogs = Array.isArray(logs) ? logs : []; 
        renderizarInterfaceLogs();
    } catch (e) {}
}

function renderizarInterfaceLogs() {
    const lista = document.getElementById("listaLogs");
    if (!lista) return;
    lista.innerHTML = cacheLogs.slice(0, 5).map(log => `<div class="update-item">● ${log.texto || log}</div>`).join('');
}

document.addEventListener("DOMContentLoaded", function() {
    const usuariosPadrao = [{ usuario: "admin", senha: "1234", primeiroAcesso: true }, { usuario: "mauro", senha: "0000", primeiroAcesso: true }];
    let usuariosDB = JSON.parse(localStorage.getItem("usuarios_dgf")) || usuariosPadrao;

    const mainContainer = document.getElementById("mainContainer");
    const loginArea = document.getElementById("loginArea");
    const sistemaArea = document.getElementById("sistemaArea");
    const dashLateral = document.getElementById("dashboardDireito");
    const trocaSenhaArea = document.getElementById("trocaSenhaArea");

    window.verSenha = function(id) {
        const input = document.getElementById(id);
        input.type = input.type === "password" ? "text" : "password";
    }

    window.login = function() {
        const user = usuariosDB.find(u => u.usuario === document.getElementById("usuario").value.trim() && u.senha === document.getElementById("senha").value.trim());
        if (user) {
            localStorage.setItem("userLogando", user.usuario);
            if (user.primeiroAcesso) { loginArea.classList.add("hidden"); trocaSenhaArea.classList.remove("hidden"); } 
            else { confirmarEntrada(); }
        } else alert("Usuário ou senha inválidos.");
    }

    window.salvarNovaSenha = function() {
        const n = document.getElementById("novaSenha").value;
        const loginUser = localStorage.getItem("userLogando");
        usuariosDB = usuariosDB.map(u => u.usuario === loginUser ? {...u, senha: n, primeiroAcesso: false} : u);
        localStorage.setItem("usuarios_dgf", JSON.stringify(usuariosDB));
        confirmarEntrada();
    }

    function confirmarEntrada() {
        localStorage.setItem("logado", "true");
        localStorage.setItem("tempoLogin", Date.now());
        mainContainer.classList.add("modo-sistema");
        loginArea.classList.add("hidden"); trocaSenhaArea.classList.add("hidden");
        sistemaArea.classList.remove("hidden"); dashLateral.classList.remove("hidden");
        carregarLogs();
    }

    window.logout = function() { localStorage.clear(); location.reload(); }

    window.consultar = async function() {
        let p = document.getElementById("pergunta").value.trim().toLowerCase();
        if (!p) return;
        document.getElementById("resposta").innerHTML = "Buscando...";
        try {
            const res = await fetch(WEBHOOK_URL);
            const data = await res.json();
            let r = data.filter(f => f.nome.toLowerCase().includes(p) || f.setor.toLowerCase().includes(p) || f.cargo.toLowerCase().includes(p));
            if (!r.length) return document.getElementById("resposta").innerHTML = "Nada encontrado.";
            document.getElementById("resposta").innerHTML = r.map(f => `
                <div class="card-resultado">
                    <strong>${f.nome}</strong><br><small>${f.setor} | ${f.cargo}</small>
                </div>
            `).join('');
        } catch (e) { document.getElementById("resposta").innerHTML = "Erro."; }
    }

    if (localStorage.getItem("logado") === "true") confirmarEntrada();
});
</script>
</body>
</html>
